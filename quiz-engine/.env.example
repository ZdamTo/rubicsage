# ── Supabase (required) ───────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-only – NEVER expose this in the browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Super Admins ──────────────────────────────────────────────────────────────
# Comma-separated list of emails that get super_admin role on first login
SUPER_ADMIN_EMAILS=admin@example.com,another@example.com

# ── AI Provider API Keys (server-side only) ───────────────────────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...

# ── Default AI settings ───────────────────────────────────────────────────────
DEFAULT_AI_PROVIDER=openai
DEFAULT_OPENAI_MODEL=gpt-4o
DEFAULT_GEMINI_MODEL=gemini-2.5-flash
DEFAULT_CLAUDE_MODEL=claude-sonnet-4-5-20250929
